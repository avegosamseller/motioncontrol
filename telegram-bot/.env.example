# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Magnific API Key (from magnific.com)
MAGNIFIC_API_KEY=your_magnific_api_key_here

# Your domain for serving uploaded files (with https://)
# Example: https://yourdomain.com
BASE_URL=https://yourdomain.com

# Upload directory path on server (files will be served via nginx)
UPLOAD_DIR=/var/www/uploads

# Nginx upload URL path (must match nginx config)
UPLOAD_URL_PATH=/uploads
